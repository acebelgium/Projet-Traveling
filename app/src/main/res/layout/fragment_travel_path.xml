<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="TravelPath"
                android:textColor="@color/on_background"
                android:textSize="32sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Votre guide sur mesure"
                android:textColor="@color/on_surface_variant"
                android:textSize="16sp" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="DESTINATIONS"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingEnd="24dp">
                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                <Button
                    android:id="@+id/btn_mes_favoris"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mes Itinéraires"
                    android:textColor="@color/primary"
                    app:icon="@android:drawable/btn_star_big_on" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingStart="24dp"
                android:clipToPadding="false"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/ll_villes_cards"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Paris -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_paris"
                        android:layout_width="120dp"
                        android:layout_height="160dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp">
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@android:drawable/ic_menu_gallery" android:id="@+id/iv_paris" />
                            <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#4D000000" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Paris" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_gravity="bottom|center_horizontal" android:layout_marginBottom="12dp" />
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Londres -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_london"
                        android:layout_width="120dp"
                        android:layout_height="160dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp">
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@android:drawable/ic_menu_gallery" android:id="@+id/iv_london" />
                            <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#4D000000" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Londres" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_gravity="bottom|center_horizontal" android:layout_marginBottom="12dp" />
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- NY -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_ny"
                        android:layout_width="120dp"
                        android:layout_height="160dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp">
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@android:drawable/ic_menu_gallery" android:id="@+id/iv_ny" />
                            <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#4D000000" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="New York" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_gravity="bottom|center_horizontal" android:layout_marginBottom="12dp" />
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Card Preferences -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VOTRE VOYAGE"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_ville"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Saisir une ville..."
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tv_budget_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Budget : 100€"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="14sp" />

                    <SeekBar
                        android:id="@+id/sb_budget"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:max="1000"
                        android:progress="100" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Accessibilité &amp; Profil"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="14sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/cg_profils"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_prm"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PMR / Mobilité réduite" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_senior"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sénior" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_enfant"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enfants" />
                    </com.google.android.material.chip.ChipGroup>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Catégories d'activités"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="14sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/cg_categories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_musees"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Musées" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_parcs"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Parcs &amp; Jardins" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_monuments"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monuments" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_resto"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Restauration" />
                    </com.google.android.material.chip.ChipGroup>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_meteo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Adapter selon la météo"
                        android:textColor="@color/on_surface" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_generer"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="32dp"
                        app:backgroundTint="@color/primary"
                        android:text="Calculer mon itinéraire"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:cornerRadius="32dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>